{
  "name": "@archonvii/archon-setup",
  "version": "0.1.0",
  "description": "Plug-and-play repo bootstrapper for the ArchonVII ecosystem. Local browser wizard that scaffolds a new repo with AGENTS.md, workflows, labels, and branch protection.",
  "type": "module",
  "bin": {
    "archon-setup": "bin/archon-setup.mjs"
  },
  "scripts": {
    "start": "node bin/archon-setup.mjs",
    "dev": "node bin/archon-setup.mjs --dev",
    "onboard": "node bin/onboard.mjs",
    "agent:close-preflight": "node scripts/agent-close-preflight.mjs",
    "agent:pr-ready": "node scripts/agent-pr-ready.mjs",
    "refresh-snapshots": "node scripts/refresh-snapshots.mjs",
    "snapshot": "node bin/ecosystem-snapshot.mjs",
    "test": "node --test \"test/*.test.mjs\"",
    "prepublishOnly": "node scripts/prepublish-check.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin/",
    "src/",
    "install.ps1",
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "scaffold",
    "bootstrap",
    "agents",
    "github",
    "archonvii"
  ],
  "license": "MIT",
  "author": "Joseph Maguirre"
}
