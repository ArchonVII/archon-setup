{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "archon-setup/contracts/operation-mapping",
  "title": "Shape of src/contracts/operation-mapping.json; completeness and exactly-one matching are asserted behaviorally in test/operationMapping.test.mjs",
  "type": "object",
  "required": ["schemaVersion", "kind", "rows"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "operation-mapping" },
    "title": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rowId", "when", "operation", "recommended", "recommendationReason", "requiresConfirmation", "options"],
        "additionalProperties": false,
        "properties": {
          "rowId": { "type": "string", "minLength": 1 },
          "when": {
            "type": "object",
            "required": ["status", "changed", "created"],
            "additionalProperties": false,
            "properties": {
              "status": { "enum": ["clean_apply", "adoption_needed", "conflict", "skip", "failed"] },
              "changed": { "type": ["boolean", "null"] },
              "created": { "type": ["boolean", "null"] }
            }
          },
          "operation": {
            "type": "object",
            "required": ["action", "currentState"],
            "additionalProperties": false,
            "properties": {
              "action": { "enum": ["create", "overwrite", "merge", "skip", "blocked", "needs_review"] },
              "currentState": { "enum": ["missing", "present", "drifted", "unknown", null] }
            }
          },
          "recommended": { "enum": ["apply-central", "keep-local", "merge-manual", "defer", null] },
          "recommendationReason": {
            "enum": [
              "managed-region-clean-update",
              "managed-region-create",
              "already-current",
              "adoption-needs-confirmation",
              "not-applicable",
              "blocked-conflict-requires-human-resolution",
              "blocked-operational-failure"
            ]
          },
          "requiresConfirmation": { "type": "boolean" },
          "options": {
            "type": "array",
            "items": { "enum": ["apply-central", "keep-local", "merge-manual", "defer"] }
          }
        }
      }
    }
  }
}
