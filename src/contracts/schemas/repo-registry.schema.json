{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "archon-setup/contracts/repo-registry",
  "title": "Repo registry (tracked seed and user overlay share this shape): the canonical list of ecosystem repositories; #214 lane 1 of the ecosystem-registry rollout",
  "type": "object",
  "required": ["schemaVersion", "repositories"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "updatedAt": { "type": ["string", "null"] },
    "description": { "type": "string" },
    "repositories": { "type": "array", "items": { "$ref": "#/$defs/entry" } }
  },
  "$defs": {
    "isoDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "entry": {
      "type": "object",
      "required": ["id", "name", "owner", "repo", "path", "lifecycle", "healthTarget", "role"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "lifecycle": { "enum": ["active", "inactive", "removed"] },
        "healthTarget": { "type": "boolean" },
        "role": {
          "enum": [
            "application",
            "workflow-provider",
            "baseline-provider",
            "org-defaults-provider",
            "ecosystem-health-hub",
            "skill-source"
          ]
        },
        "reservedPorts": { "type": "array", "items": { "$ref": "#/$defs/port" } },
        "devServer": {
          "type": "object",
          "required": ["kind", "primaryPort"],
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "minLength": 1 },
            "primaryPort": { "$ref": "#/$defs/port" },
            "command": { "type": "string", "minLength": 1 }
          }
        },
        "notes": { "type": "string" },
        "reason": { "type": "string" },
        "addedAt": { "$ref": "#/$defs/isoDate" },
        "updatedAt": { "$ref": "#/$defs/isoDate" },
        "removedAt": { "$ref": "#/$defs/isoDate" }
      }
    }
  }
}
