{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "archon-setup/contracts/run-state-machine",
  "title": "Shape of src/contracts/run-states.json (states + invariants table); semantic consistency is asserted separately in test/contractSchemas.test.mjs",
  "type": "object",
  "required": ["schemaVersion", "kind", "initial", "states", "transitions", "wildcardTransitions"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "run-state-machine" },
    "title": { "type": "string" },
    "terminalRule": { "type": "string" },
    "initial": { "type": "string", "minLength": 1 },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "terminal", "requires"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "terminal": { "type": "boolean" },
          "requires": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "notes": { "type": "string" }
        }
      }
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 }
        }
      }
    },
    "wildcardTransitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["to", "fromAnyNonTerminal"],
        "additionalProperties": false,
        "properties": {
          "to": { "type": "string", "minLength": 1 },
          "fromAnyNonTerminal": { "type": "boolean" },
          "excludeFrom": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
